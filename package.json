{
    "name": "@moduletrace/bunext",
    "module": "index.ts",
    "type": "module",
    "version": "1.0.52",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "default": "./dist/index.js"
        },
        "./types": {
            "types": "./dist/types/index.d.ts",
            "import": "./dist/types/index.js",
            "default": "./dist/types/index.js"
        }
    },
    "bin": {
        "bunext": "dist/commands/index.js"
    },
    "files": [
        "dist",
        "README.md",
        "package.json"
    ],
    "scripts": {
        "dev": "tsc --watch",
        "git:push": "tsc --noEmit && tsc && git add . && git commit -m 'Update init. Remove uneccessary directores creation' && git push",
        "compile": "bun build ./src/commands/index.ts --compile --outfile bin/bunext --minify",
        "build": "tsc",
        "test": "bun test --max-concurrency=1"
    },
    "devDependencies": {
        "@testing-library/dom": "^10.4.1",
        "@types/lodash": "^4.17.24",
        "@types/micromatch": "^4.0.10",
        "happy-dom": "^20.8.4"
    },
    "publishConfig": {
        "registry": "https://npm.pkg.github.com"
    },
    "dependencies": {
        "typescript": "^5.0.0",
        "react": "19.0.0",
        "react-dom": "19.0.0",
        "@tailwindcss/postcss": "^4.2.2",
        "@types/bun": "latest",
        "@types/node": "^24.10.0",
        "@types/react": "^19.2.2",
        "@types/react-dom": "^19.2.2",
        "bun-plugin-tailwind": "^0.1.2",
        "chalk": "^5.6.2",
        "commander": "^14.0.2",
        "esbuild": "^0.27.4",
        "lightningcss-wasm": "^1.32.0",
        "lodash": "^4.17.23",
        "micromatch": "^4.0.8",
        "ora": "^9.0.0",
        "postcss": "^8.5.8",
        "tailwindcss": "^4.2.2"
    }
}
